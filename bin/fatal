#!/bin/bash
# fatal-lyrics — letras de Spotify como diálogos de error de Windows.
# Relocatable: funciona desde el repo clonado o instalado en /usr/share/fatal-lyrics.
SELF="$(readlink -f "$0")"
BASE="${CARTELITOS_HOME:-$(dirname "$(dirname "$SELF")")}"
QML="$BASE/shell/shell.qml"
DAEMON="$BASE/cartelitos.py"
CONFIG="${XDG_CONFIG_HOME:-$HOME/.config}/cartelitos/config.toml"

QS_PID=/tmp/cartelitos-qs.pid
D_PID=/tmp/cartelitos-daemon.pid
SOCK="${XDG_RUNTIME_DIR:-/run/user/$UID}/cartelitos.sock"

running() { [ -f "$1" ] && kill -0 "$(cat "$1")" 2>/dev/null; }

start() {
    if [ ! -f "$QML" ] || [ ! -f "$DAEMON" ]; then
        echo "no encuentro los archivos de fatal-lyrics en $BASE" >&2
        exit 1
    fi
    if ! running $QS_PID; then
        qs -p "$QML" >/tmp/cartelitos-qs.log 2>&1 &
        echo $! > $QS_PID
    fi
    # esperar a que el overlay levante el socket antes de arrancar el daemon
    for _ in $(seq 1 25); do
        [ -S "$SOCK" ] && break
        sleep 0.2
    done
    if ! running $D_PID; then
        python3 "$DAEMON" >/tmp/cartelitos.log 2>&1 &
        echo $! > $D_PID
    fi
    echo "fatal ON"
}

stop() {
    for f in $D_PID $QS_PID; do
        running "$f" && kill "$(cat "$f")" 2>/dev/null
        rm -f "$f"
    done
    # sin esto, el próximo start ve el socket viejo y arranca el daemon antes de tiempo
    rm -f "$SOCK"
    echo "fatal OFF"
}

case "${1:-toggle}" in
    on|start)  start ;;
    off|stop)  stop ;;
    restart)   stop; sleep 0.5; start ;;
    status)    running $D_PID && echo ON || echo OFF ;;
    toggle)    running $D_PID && stop || start ;;
    config)    ${EDITOR:-nano} "$CONFIG"; echo "aplicá los cambios con: fatal restart" ;;
    setup)     python3 "$DAEMON" --setup ;;
    *)         echo "uso: fatal [on|off|toggle|restart|status|config|setup]" ;;
esac
